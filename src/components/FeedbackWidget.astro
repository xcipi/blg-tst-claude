---
// FeedbackWidget.astro
// Feedback button + modal pre blog
// Integruje sa s /api/feedback endpointom na feedback.shadowguide.eu
---

<!-- Feedback button — fixný v pravom dolnom rohu -->
<div id="feedback-widget">
  <button
    id="feedback-btn"
    aria-label="Nahlásiť bug alebo nápad"
    title="Nahlásiť bug alebo nápad"
  >
    <span class="feedback-btn-icon">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
      </svg>
    </span>
    <span class="feedback-btn-label">feedback</span>
  </button>

  <!-- Modal overlay -->
  <div id="feedback-overlay" class="feedback-overlay" aria-hidden="true">
    <div id="feedback-modal" class="feedback-modal" role="dialog" aria-modal="true" aria-labelledby="feedback-title">
      
      <!-- Header -->
      <div class="feedback-header">
        <div class="feedback-prompt">
          <span class="feedback-prompt-symbol">$</span>
          <span id="feedback-title" class="feedback-prompt-text">submit --type [bug|feature|typo]</span>
        </div>
        <button id="feedback-close" class="feedback-close" aria-label="Zavrieť">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
      </div>

      <!-- Form -->
      <div id="feedback-form-container">
        <form id="feedback-form" class="feedback-form" novalidate>
          
          <!-- Type selector -->
          <div class="feedback-field">
            <label class="feedback-label">
              <span class="feedback-label-symbol">--type</span>
            </label>
            <div class="feedback-type-group" role="group" aria-label="Typ feedbacku">
              <label class="feedback-type-option">
                <input type="radio" name="type" value="bug" required />
                <span class="feedback-type-btn">
                  <span class="feedback-type-icon">🐛</span>
                  bug
                </span>
              </label>
              <label class="feedback-type-option">
                <input type="radio" name="type" value="feature" />
                <span class="feedback-type-btn">
                  <span class="feedback-type-icon">💡</span>
                  feature
                </span>
              </label>
              <label class="feedback-type-option">
                <input type="radio" name="type" value="typo" />
                <span class="feedback-type-btn">
                  <span class="feedback-type-icon">✏️</span>
                  typo
                </span>
              </label>
            </div>
          </div>

          <!-- Title -->
          <div class="feedback-field">
            <label class="feedback-label" for="feedback-title-input">
              <span class="feedback-label-symbol">--title</span>
              <span class="feedback-label-hint">5–200 znakov</span>
            </label>
            <input
              id="feedback-title-input"
              type="text"
              name="title"
              class="feedback-input"
              placeholder="Krátky popis..."
              minlength="5"
              maxlength="200"
              required
            />
          </div>

          <!-- Description -->
          <div class="feedback-field">
            <label class="feedback-label" for="feedback-desc">
              <span class="feedback-label-symbol">--description</span>
              <span class="feedback-label-hint">10–4000 znakov</span>
            </label>
            <textarea
              id="feedback-desc"
              name="description"
              class="feedback-input feedback-textarea"
              placeholder="Podrobnejší popis, kroky na reprodukciu, návrh..."
              minlength="10"
              maxlength="4000"
              rows="4"
              required
            ></textarea>
            <div class="feedback-char-count">
              <span id="feedback-char-count">0</span>/4000
            </div>
          </div>

          <!-- Context URL (auto-filled) -->
          <input type="hidden" name="context_url" id="feedback-context-url" />

          <!-- Submit -->
          <div class="feedback-actions">
            <div class="feedback-context-info">
              <span class="feedback-context-label">kontext:</span>
              <span id="feedback-context-display" class="feedback-context-value"></span>
            </div>
            <button type="submit" id="feedback-submit" class="feedback-submit">
              <span id="feedback-submit-text">submit</span>
              <svg id="feedback-submit-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="9 18 15 12 9 6"></polyline>
              </svg>
            </button>
          </div>

          <!-- Error message -->
          <div id="feedback-error" class="feedback-message feedback-error" aria-live="polite" hidden>
            <span class="feedback-message-icon">✗</span>
            <span id="feedback-error-text"></span>
          </div>
        </form>
      </div>

      <!-- Success state -->
      <div id="feedback-success" class="feedback-success" hidden>
        <div class="feedback-success-icon">✓</div>
        <div class="feedback-success-text">
          <div class="feedback-success-title">Submit prijatý</div>
          <div class="feedback-success-id" id="feedback-success-id"></div>
        </div>
      </div>

    </div>
  </div>
</div>

<style>
  /* Base */
  #feedback-widget {
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    z-index: 9999;
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
  }

  /* Button */
  #feedback-btn {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.875rem;
    background: #0a0a0a;
    border: 1px solid #374151;
    border-radius: 0.375rem;
    color: #6b7280;
    font-family: inherit;
    font-size: 0.75rem;
    cursor: pointer;
    transition: all 0.2s;
  }

  #feedback-btn:hover {
    border-color: #10b981;
    color: #10b981;
  }

  .feedback-btn-icon {
    display: flex;
    align-items: center;
  }

  /* Overlay */
  .feedback-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.7);
    display: flex;
    align-items: flex-end;
    justify-content: flex-end;
    padding: 1.5rem;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s;
  }

  .feedback-overlay.is-open {
    opacity: 1;
    pointer-events: all;
  }

  /* Modal */
  .feedback-modal {
    width: 100%;
    max-width: 440px;
    background: #111111;
    border: 1px solid #1f2937;
    border-radius: 0.5rem;
    overflow: hidden;
    transform: translateY(1rem);
    transition: transform 0.2s;
  }

  .feedback-overlay.is-open .feedback-modal {
    transform: translateY(0);
  }

  /* Header */
  .feedback-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid #1f2937;
    background: #0a0a0a;
  }

  .feedback-prompt {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .feedback-prompt-symbol {
    color: #10b981;
    font-size: 0.75rem;
  }

  .feedback-prompt-text {
    color: #6b7280;
    font-size: 0.7rem;
  }

  .feedback-close {
    background: none;
    border: none;
    color: #4b5563;
    cursor: pointer;
    padding: 0.25rem;
    display: flex;
    align-items: center;
    transition: color 0.15s;
  }

  .feedback-close:hover {
    color: #10b981;
  }

  /* Form */
  .feedback-form {
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }

  .feedback-field {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .feedback-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .feedback-label-symbol {
    color: #10b981;
    font-size: 0.7rem;
  }

  .feedback-label-hint {
    color: #374151;
    font-size: 0.65rem;
  }

  /* Type selector */
  .feedback-type-group {
    display: flex;
    gap: 0.5rem;
  }

  .feedback-type-option input {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
  }

  .feedback-type-btn {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.375rem 0.625rem;
    background: #0a0a0a;
    border: 1px solid #1f2937;
    border-radius: 0.25rem;
    color: #6b7280;
    font-family: inherit;
    font-size: 0.7rem;
    cursor: pointer;
    transition: all 0.15s;
    user-select: none;
  }

  .feedback-type-btn:hover {
    border-color: #374151;
    color: #9ca3af;
  }

  .feedback-type-option input:checked + .feedback-type-btn {
    border-color: #10b981;
    color: #10b981;
    background: rgba(16, 185, 129, 0.05);
  }

  /* Input */
  .feedback-input {
    background: #0a0a0a;
    border: 1px solid #1f2937;
    border-radius: 0.25rem;
    padding: 0.5rem 0.625rem;
    color: #e5e7eb;
    font-family: inherit;
    font-size: 0.75rem;
    transition: border-color 0.15s;
    outline: none;
    width: 100%;
    box-sizing: border-box;
  }

  .feedback-input::placeholder {
    color: #374151;
  }

  .feedback-input:focus {
    border-color: #10b981;
  }

  .feedback-textarea {
    resize: vertical;
    min-height: 80px;
  }

  .feedback-char-count {
    text-align: right;
    color: #374151;
    font-size: 0.65rem;
    margin-top: 0.25rem;
  }

  /* Actions */
  .feedback-actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    padding-top: 0.25rem;
  }

  .feedback-context-info {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    overflow: hidden;
    flex: 1;
  }

  .feedback-context-label {
    color: #374151;
    font-size: 0.65rem;
    flex-shrink: 0;
  }

  .feedback-context-value {
    color: #4b5563;
    font-size: 0.65rem;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .feedback-submit {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.5rem 1rem;
    background: #10b981;
    border: none;
    border-radius: 0.25rem;
    color: #000;
    font-family: inherit;
    font-size: 0.75rem;
    font-weight: 700;
    cursor: pointer;
    transition: background 0.15s;
    flex-shrink: 0;
  }

  .feedback-submit:hover {
    background: #059669;
  }

  .feedback-submit:disabled {
    background: #1f2937;
    color: #4b5563;
    cursor: not-allowed;
  }

  /* Messages */
  .feedback-message {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.625rem;
    border-radius: 0.25rem;
    font-size: 0.7rem;
  }

  .feedback-error {
    background: rgba(239, 68, 68, 0.1);
    border: 1px solid rgba(239, 68, 68, 0.3);
    color: #f87171;
  }

  .feedback-message-icon {
    flex-shrink: 0;
  }

  /* Hidden attribute fix */
  [hidden] { display: none !important; }

  /* Success */
  .feedback-success {
    padding: 2rem 1rem;
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .feedback-success-icon {
    width: 2rem;
    height: 2rem;
    background: rgba(16, 185, 129, 0.1);
    border: 1px solid #10b981;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #10b981;
    font-size: 0.875rem;
    flex-shrink: 0;
  }

  .feedback-success-title {
    color: #10b981;
    font-size: 0.875rem;
    font-weight: 700;
  }

  .feedback-success-id {
    color: #4b5563;
    font-size: 0.65rem;
    margin-top: 0.25rem;
  }

  /* Loading state */
  .feedback-submit.is-loading #feedback-submit-text::after {
    content: '...';
  }

  @media (max-width: 480px) {
    #feedback-widget {
      bottom: 1rem;
      right: 1rem;
      left: 1rem;
    }

    .feedback-overlay {
      padding: 1rem;
      align-items: flex-end;
    }

    .feedback-modal {
      max-width: 100%;
    }
  }
</style>

<script>
  const FEEDBACK_API = 'https://feedback.shadowguide.eu/api/feedback';

  const btn = document.getElementById('feedback-btn')!;
  const overlay = document.getElementById('feedback-overlay')!;
  const closeBtn = document.getElementById('feedback-close')!;
  const form = document.getElementById('feedback-form') as HTMLFormElement;
  const submitBtn = document.getElementById('feedback-submit') as HTMLButtonElement;
  const submitText = document.getElementById('feedback-submit-text')!;
  const errorEl = document.getElementById('feedback-error')!;
  const errorText = document.getElementById('feedback-error-text')!;
  const successEl = document.getElementById('feedback-success')!;
  const successId = document.getElementById('feedback-success-id')!;
  const contextUrl = document.getElementById('feedback-context-url') as HTMLInputElement;
  const contextDisplay = document.getElementById('feedback-context-display')!;
  const charCount = document.getElementById('feedback-char-count')!;
  const descArea = document.getElementById('feedback-desc') as HTMLTextAreaElement;

  function openModal() {
    // Auto-fill context URL
    const url = window.location.href;
    contextUrl.value = url;
    contextDisplay.textContent = url.replace('https://www.shadowguide.eu', '').replace('https://shadowguide.eu', '') || '/';

    overlay.classList.add('is-open');
    overlay.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';

    // Reset form state
    errorEl.hidden = true;
    successEl.hidden = true;
    form.style.display = 'flex';
    form.reset();
    charCount.textContent = '0';
  }

  function closeModal() {
    overlay.classList.remove('is-open');
    overlay.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  btn.addEventListener('click', openModal);
  closeBtn.addEventListener('click', closeModal);

  overlay.addEventListener('click', (e) => {
    if (e.target === overlay) closeModal();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && overlay.classList.contains('is-open')) closeModal();
  });

  descArea.addEventListener('input', () => {
    charCount.textContent = String(descArea.value.length);
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    errorEl.hidden = true;

    const data = new FormData(form);
    const type = data.get('type') as string;
    const title = data.get('title') as string;
    const description = data.get('description') as string;
    const context_url = contextUrl.value;

    // Basic client-side validation
    if (!type) {
      showError('Vyber typ feedbacku');
      return;
    }
    if (!title || title.length < 5) {
      showError('Názov musí mať aspoň 5 znakov');
      return;
    }
    if (!description || description.length < 10) {
      showError('Popis musí mať aspoň 10 znakov');
      return;
    }

    // Loading state
    submitBtn.disabled = true;
    submitBtn.classList.add('is-loading');
    submitText.textContent = 'odosielam';

    try {
      const response = await fetch(FEEDBACK_API, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify({ type, title, description, context_url }),
      });

      const result = await response.json() as { success?: boolean; submit_id?: string; error?: string };

      if (response.ok && result.success) {
        // Show success
        form.style.display = 'none';
        successEl.hidden = false;
        successId.textContent = `id: ${result.submit_id}`;

        // Auto-close after 3s
        setTimeout(closeModal, 3000);
      } else if (response.status === 401) {
        showError('Prihlás sa cez Cloudflare Access a skús znovu');
      } else {
        showError(result.error ?? 'Niečo sa pokazilo, skús neskôr');
      }
    } catch {
      showError('Sieťová chyba, skontroluj pripojenie');
    } finally {
      submitBtn.disabled = false;
      submitBtn.classList.remove('is-loading');
      submitText.textContent = 'submit';
    }
  });

  function showError(msg: string) {
    errorText.textContent = msg;
    errorEl.hidden = false;
  }
</script>
